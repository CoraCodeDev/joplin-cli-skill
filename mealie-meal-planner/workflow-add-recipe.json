{
  "name": "Mealie - Add Recipe",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "add-recipe",
        "options": {}
      },
      "id": "webhook-add-recipe",
      "name": "Webhook: Add Recipe",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300],
      "webhookId": "mealie-add-recipe"
    },
    {
      "parameters": {
        "functionCode": "const data = $json;\n\n// Simple ID generator for instructions\nfunction generateId() {\n    return 'cda6187d' + Math.random().toString(36).substring(2, 11).padEnd(8, '0');\n}\n\n// Transform ingredients if present\nif (data.type === 'manual' && data.recipe && data.recipe.ingredients) {\n    const ingredients = data.recipe.ingredients.map(ing => {\n        const amount = ing.amount || '';\n        const unit = ing.unit || '';\n        const name = ing.name || '';\n        const originalText = [amount, unit, name].filter(Boolean).join(' ');\n        \n        return {\n            quantity: parseFloat(amount) || 0,\n            unit: unit ? { name: unit } : null,\n            note: originalText,\n            originalText: originalText,\n            display: originalText\n        };\n    });\n    \n    data.recipe.recipeIngredient = ingredients;\n}\n\n// Tags as array\nif (data.recipe && data.recipe.tags) {\n    const tags = data.recipe.tags;\n    data.recipe.tags = tags.map(t => typeof t === 'string' ? {name: t} : t);\n}\n\n// Process instructions - ensure explicit IDs for each step\nif (data.recipe && data.recipe.instructions) {\n    if (typeof data.recipe.instructions === 'string') {\n        // Wrap string as array with IDs\n        const steps = data.recipe.instructions.split('\\n').filter(s => s.trim());\n        data.recipe.recipeInstructions = steps.map((text, i) => ({\n            title: null,\n            text: text.trim(),\n            order: i + 1,\n            id: generateId()\n        }));\n    } else {\n        // Pass array through but ensure all have IDs\n        data.recipe.recipeInstructions = data.recipe.instructions.map((inst, i) => ({\n            ...inst,\n            id: inst.id || generateId()\n        }));\n    }\n}\n\nreturn [{ json: data }];"
      },
      "id": "parse-input",
      "name": "Parse Input",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [500, 300]
    },
    {
