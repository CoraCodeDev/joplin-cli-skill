    {
      "parameters": {
        "functionCode": "// Debug: show what we're about to send\nconst recipe = $json.recipe || $json;\nreturn [{\n    json: {\n        debug: true,\n        recipe: JSON.stringify(recipe, null, 2),\n        hasIngredients: !!recipe.recipeIngredient,\n        hasInstructions: !!recipe.recipeInstructions,\n        hasInstructionIds: recipe.recipeInstructions?.every(i => i.id) || false,\n        hasTags: !!recipe.tags\n    }\n}];"
      },
